# ===========================================
# Trend Battle - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in launch values.
# The app runs without the optional analytics and ad variables.

# -------------------------------------------
# App Configuration
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------
# Google Search Console / SEO
# -------------------------------------------
# Paste the token from the Google "HTML tag" verification method.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# -------------------------------------------
# Google AdSense
# -------------------------------------------
# Use the client id form, for example: ca-pub-4981986991458105
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=

# public/ads.txt must contain the matching publisher id form:
# google.com, pub-4981986991458105, DIRECT, f08c47fec0942fa0

# -------------------------------------------
# Analytics (Optional)
# -------------------------------------------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
